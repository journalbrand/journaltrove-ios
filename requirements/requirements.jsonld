    },
    {
      "id": "System.2.1.iOS.1",
      "type": "Requirement",
      "name": "iOS Secure Enclave Key Generation",
      "description": "The iOS client shall generate identity keys exclusively within the device Secure Enclave",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.2.1"
    },
    {
      "id": "System.2.2.iOS.1",
      "type": "Requirement",
      "name": "iOS Biometric/PIN Authorization",
      "description": "The iOS client shall require biometric or PIN authorization for all identity key operations",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.2.2"
    },
    {
      "id": "System.2.3.iOS.1",
      "type": "Requirement",
      "name": "iOS DID Document Publication",
      "description": "The iOS client shall publish user DID documents to IPNS via Kubo nodes",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.2.3"
    },
    {
      "id": "System.3.1.iOS.1",
      "type": "Requirement",
      "name": "iOS Journal Policy Enforcement",
      "description": "The iOS client shall enforce local cryptographic checks of journal policy at member invite/update",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.3.1"
    },
    {
      "id": "System.3.2.iOS.1",
      "type": "Requirement",
      "name": "iOS Identity Update Notifications",
      "description": "The iOS client shall provide explicit UI notifications for identity metadata updates, requiring user acceptance",
      "status": "Draft",
      "priority": "Medium",
      "component": "iOS",
      "parent": "System.3.2"
    },
    {
      "id": "System.3.1.iOS.2",
      "type": "Requirement",
      "name": "iOS Journal Creation",
      "description": "The iOS client shall enable users to create new journals with defined policies",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.3.1"
    },
    {
      "id": "System.4.1.iOS.1",
      "type": "Requirement",
      "name": "iOS Local Robot Support",
      "description": "The iOS client shall support local robots with secure enclave-stored identities",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.4.1"
    },
    {
      "id": "System.4.2.iOS.1",
      "type": "Requirement",
      "name": "iOS Robot Owner Reference",
      "description": "Local robots on iOS shall explicitly reference human owner DIDs and be signed by owner private keys",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.4.2"
    },
    {
      "id": "System.4.3.iOS.1",
      "type": "Requirement",
      "name": "iOS Robot Capability Metadata",
      "description": "Local robots on iOS shall have explicit capability metadata signed by the owner",
      "status": "Draft",
      "priority": "Medium",
      "component": "iOS",
      "parent": "System.4.3"
    },
    {
      "id": "System.5.1.iOS.1",
      "type": "Requirement",
      "name": "iOS Hardware Attestation",
      "description": "The iOS client shall enforce hardware attestation verification at DID import/addition",
      "status": "Draft",
      "priority": "High",
      "component": "iOS",
      "parent": "System.5.1"
